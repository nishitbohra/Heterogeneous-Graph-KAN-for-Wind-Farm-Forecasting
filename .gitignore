# .gitignore for Wind Spatio-Temporal Forecasting Project

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# PyTorch
*.pth
*.pt
*.ckpt

# Data files (keep structure, ignore large files)
data/raw/*.csv
data/processed/*.pkl
data/processed/*.npy
data/processed/*.npz

# Model checkpoints
checkpoints/*.pth
checkpoints/*.pt
checkpoints/**/

# Results and outputs
results/*.png
results/*.pdf
results/*.json
results/*.npz

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!checkpoints/.gitkeep
!results/.gitkeep

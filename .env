# HG-KAN Wind Forecasting API Configuration

# Application Settings
APP_NAME=HG-KAN Wind Forecasting API
APP_VERSION=1.0.0
DEBUG=False

# API Configuration
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
RELOAD=False

# CORS - Add your frontend URLs here
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:8000

# File Upload Limits
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=.csv,.npz,.npy

# Model Configuration
MODEL_TYPE=HG-KAN
NUM_NODES=200
INPUT_WINDOW=24
FORECAST_HORIZON=6
HIDDEN_DIM=64
NUM_BASIS=5

# Graph Configuration
EDGE_TYPES=spatial,wake,correlation
KNN_K=8
WAKE_MAX_DISTANCE_KM=5.0
CORRELATION_THRESHOLD=0.7

# Paths (relative to project root)
# PROJECT_ROOT will be automatically detected
# Uncomment and set if you have a trained model checkpoint:
# MODEL_CHECKPOINT=checkpoints/best_model.pth

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Performance
DEVICE=cpu
NUM_WORKERS=4
BATCH_SIZE=32

# Optional: Uncomment for GPU usage
# DEVICE=cuda
